# 전역 설정
IS_REAL_TRADING=false

# [실전투자 PROD]
PROD_KIS_APP_KEY=your_real_app_key
PROD_KIS_APP_SECRET=your_real_app_secret
PROD_KIS_ACCOUNT_NO=실전계좌번호8자리01

# [모의투자 PAPER]
PAPER_KIS_APP_KEY=your_virtual_app_key
PAPER_KIS_APP_SECRET=your_virtual_app_secret
PAPER_KIS_ACCOUNT_NO=모의계좌번호8자리01

# [AI] - Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# [DATABASE] - Supabase Connection String
DATABASE_URL=postgresql://postgres:password@db_host:5432/postgres

# [SAFETY]
CONFIRM_LIVE_ORDERS=false
EMERGENCY_STOP=false

# [STRATEGY]
MAX_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=5.0
SYMBOL_LOSS_LIMIT_PCT=2.0
